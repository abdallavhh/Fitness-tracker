<UserControl x:Class="FitnessTracker.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:FitnessTracker.Models"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="0">
        <StackPanel MaxWidth="560" Margin="40,30,40,30" HorizontalAlignment="Stretch">
            <ItemsControl ItemsSource="{Binding Goals}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:GoalModel}">
                        <Border Style="{StaticResource Ft.Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}" Margin="0,0,0,20"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Target" FontSize="12" Foreground="{StaticResource Ft.Brush.Label}"/>
                                        <TextBlock Text="{Binding TargetLabel}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Heading}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Start Date" FontSize="12" Foreground="{StaticResource Ft.Brush.Label}"/>
                                        <TextBlock Text="{Binding StartDateDisplay}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Heading}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding ProgressPercent, StringFormat=Progress: {0:F0}%}" FontSize="13" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,8,0,8"/>

                                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" Height="10" Margin="0,0,0,16"
                                             Foreground="{StaticResource Ft.Brush.Primary}" Background="#E5E7EB" BorderThickness="0"/>

                                <Border HorizontalAlignment="Left" Background="{StaticResource Ft.Brush.PrimarySoft}" CornerRadius="20" Padding="14,6">
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Primary}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Style="{StaticResource Ft.Btn.Primary}" Content="+ Add Goal" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                    Command="{Binding AddGoalCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
