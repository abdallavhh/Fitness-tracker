<UserControl x:Class="FitnessTracker.Views.ExerciseLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:m="clr-namespace:FitnessTracker.Models"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="0">
        <StackPanel MaxWidth="1200" Margin="40,30,40,30" HorizontalAlignment="Stretch">
            <StackPanel Margin="0,0,0,16">
                <Button HorizontalAlignment="Left" Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding GoBackCommand}" ToolTip="Back">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                </Button>
                <Button HorizontalAlignment="Stretch" Margin="0,10,0,0" Style="{StaticResource Ft.Btn.Primary}"
                        Content="+ Add Exercise" Command="{Binding AddExerciseCommand}"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding Exercises}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:ExerciseEntryModel}">
                        <Border Style="{StaticResource SoftShadowListItem}" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8" Background="#F3F4F6">
                                    <materialDesign:PackIcon Kind="Run" Width="26" Height="26" Foreground="#212121"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Heading}"/>
                                    <TextBlock Text="{Binding DurationCalorieLabel}" FontSize="13" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <materialDesign:PackIcon Grid.Column="2" Kind="ChevronRight" VerticalAlignment="Center" Foreground="{StaticResource Ft.Brush.Label}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource Ft.Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Calories Burned" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}" Margin="0,0,0,12"/>
                    <lvc:CartesianChart Series="{Binding SeriesCollection}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                        LegendPosition="Hidden" TooltipPosition="Hidden"
                                        MinHeight="160" MaxHeight="320" Height="220"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
