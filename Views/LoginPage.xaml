<UserControl x:Class="FitnessTracker.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:FitnessTracker.Helpers"
             Background="{StaticResource Brush.AppBackground}"
             FontFamily="{StaticResource Ft.Font.App}">

    <Grid>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="420"
                MaxWidth="420"
                Style="{StaticResource CardStyle}">
            <StackPanel>
                <Border Width="72"
                        Height="72"
                        CornerRadius="18"
                        Background="#1A11B6A4"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="HeartPulse"
                                             Width="36"
                                             Height="36"
                                             Foreground="{StaticResource Brush.PrimaryTeal}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="FITNESS TRACKER"
                           Style="{StaticResource CardTitleTextStyle}"
                           FontSize="24"
                           TextAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Login to your account"
                           Style="{StaticResource MutedLabelTextStyle}"
                           FontSize="14"
                           TextAlignment="Center"
                           Margin="0,0,0,24"/>

                <Border Background="#FFF3F0"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource Brush.DangerRed}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Border>

                <Grid Margin="0,0,0,12" Height="56">
                    <TextBox materialDesign:HintAssist.Hint="Username / Email"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Height="56"
                             VerticalAlignment="Center"
                             Padding="36,0,12,0"/>
                    <materialDesign:PackIcon Kind="AccountOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="12,0,0,0"
                                             Foreground="{StaticResource Brush.TextMuted}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             IsHitTestVisible="False"/>
                </Grid>

                <Grid Margin="0,0,0,18" Height="56">
                    <PasswordBox Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 materialDesign:HintAssist.Hint="Password"
                                 Height="56"
                                 VerticalAlignment="Center"
                                 Padding="36,0,48,0"
                                 Visibility="{Binding MaskPassword, Converter={StaticResource BoolToVis}}"
                                 helpers:PasswordBoxAssistant.BindPassword="True"
                                 helpers:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Password"
                             Height="56"
                             VerticalAlignment="Center"
                             Padding="36,0,48,0"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding MaskPassword, Converter={StaticResource InverseBoolToVis}}"/>
                    <materialDesign:PackIcon Kind="LockOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="12,0,0,0"
                                             Foreground="{StaticResource Brush.TextMuted}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             IsHitTestVisible="False"/>
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding TogglePasswordMaskCommand}">
                        <materialDesign:PackIcon Kind="EyeOutline"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource Brush.TextMuted}">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MaskPassword}" Value="False">
                                            <Setter Property="Kind" Value="EyeOffOutline"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                    </Button>
                </Grid>

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="Login"
                        Command="{Binding LoginCommand}"
                        Height="48"
                        Margin="0,0,0,14"/>

                <Button Style="{StaticResource GhostButtonStyle}"
                        Content="Create New Account"
                        Command="{Binding CreateAccountCommand}"
                        Height="44"
                        Margin="0,0,0,10"/>

                <TextBlock Text="Forgot Password?"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.PrimaryTeal}"
                           Cursor="Hand"
                           TextAlignment="Center"
                           Margin="0,2,0,16">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding ForgotPasswordCommand}"/>
                    </TextBlock.InputBindings>
                </TextBlock>

                <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ADMIN" Style="{StaticResource MutedLabelTextStyle}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="admin" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="admin" Foreground="{StaticResource Brush.TextMuted}" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="USER" Style="{StaticResource MutedLabelTextStyle}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="Mona" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="m0n@!" Foreground="{StaticResource Brush.TextMuted}" FontSize="11"/>
                    </StackPanel>

					<StackPanel Grid.Column="1">
						<TextBlock Text="ANOTHER USER" Style="{StaticResource MutedLabelTextStyle}" FontSize="11" Margin="0,0,0,4"/>
						<TextBlock Text="Ahmed" FontWeight="SemiBold" FontSize="12"/>
						<TextBlock Text="pwd123" Foreground="{StaticResource Brush.TextMuted}" FontSize="11"/>
					</StackPanel>
					
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
