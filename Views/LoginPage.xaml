<UserControl x:Class="FitnessTracker.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:FitnessTracker.Helpers"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="16,20">
        <Grid MinHeight="400">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Style="{StaticResource SoftShadowMainCard}"
                    MaxWidth="400" MinWidth="280"
                    Padding="24,28">

                <StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border Width="56" Height="56" CornerRadius="8" Background="{StaticResource Ft.Brush.PrimarySoft}">
                            <materialDesign:PackIcon Kind="HeartPulse" Width="32" Height="32"
                                                     Foreground="{StaticResource Ft.Brush.Primary}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="FITNESS TRACKER"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource Ft.Brush.Heading}"
                               TextAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Login to Your Account"
                               FontSize="14" Foreground="{StaticResource Ft.Brush.Label}"
                               TextAlignment="Center" Margin="0,0,0,28"/>

                    <Border Background="#FEE2E2" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>

                    <Grid Margin="0,0,0,12" Height="56">
                        <TextBox materialDesign:HintAssist.Hint="Username / Email"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Height="56"
                                 VerticalAlignment="Center"
                                 Padding="36,0,12,0"/>
                        <materialDesign:PackIcon Kind="AccountOutline"
                                                 Width="20" Height="20"
                                                 Margin="12,0,0,0"
                                                 Foreground="{StaticResource Ft.Brush.Label}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 IsHitTestVisible="False"/>
                    </Grid>

                    <Grid Margin="0,0,0,20" Height="56">
                        <PasswordBox x:Name="PwdBox"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="Password"
                                     Height="56"
                                     VerticalAlignment="Center"
                                     Padding="36,0,48,0"
                                     Visibility="{Binding MaskPassword, Converter={StaticResource BoolToVis}}"
                                     helpers:PasswordBoxAssistant.BindPassword="True"
                                     helpers:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Password"
                                 Height="56"
                                 VerticalAlignment="Center"
                                 Padding="36,0,48,0"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding MaskPassword, Converter={StaticResource InverseBoolToVis}}"/>
                        <materialDesign:PackIcon Kind="LockOutline"
                                                 Width="20" Height="20"
                                                 Margin="12,0,0,0"
                                                 Foreground="{StaticResource Ft.Brush.Label}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 IsHitTestVisible="False"/>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                                Width="32" Height="32"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Command="{Binding TogglePasswordMaskCommand}"
                                ToolTip="Show / hide password">
                            <materialDesign:PackIcon Kind="EyeOutline" Width="20" Height="20" Foreground="{StaticResource Ft.Brush.Label}">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MaskPassword}" Value="False">
                                                <Setter Property="Kind" Value="EyeOffOutline"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                        </Button>
                    </Grid>

                    <Button Style="{StaticResource Ft.Btn.Primary.Large}"
                            Content="Login"
                            Command="{Binding LoginCommand}"
                            Margin="0,0,0,20"/>

                    <TextBlock Text="Forgot Password?" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource Ft.Brush.Primary}" Cursor="Hand" TextAlignment="Center" Margin="0,0,0,10">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ForgotPasswordCommand}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                    <TextBlock Text="Create New Account" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource Ft.Brush.Primary}" Cursor="Hand" TextAlignment="Center">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding CreateAccountCommand}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>

                    <Border Background="{StaticResource Ft.Brush.SurfaceSubtle}" CornerRadius="8" Padding="14" Margin="0,28,0,0"
                            BorderBrush="{StaticResource Ft.Brush.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Demo sign-in" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Primary}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource Ft.Brush.Label}" LineHeight="16"
                                       Text="User: demo / password · Admin: admin / password, admin, or !"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
