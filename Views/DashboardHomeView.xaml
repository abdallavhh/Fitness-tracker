<UserControl x:Class="FitnessTracker.Views.DashboardHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,30,40,30" MaxWidth="1200" HorizontalAlignment="Stretch">
            
            <!-- 1. Top Header Row (Floating Navbar) -->
            <Border Background="White" CornerRadius="16" Padding="24,15" Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" ShadowDepth="4" BlurRadius="20" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Greeting}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}" VerticalAlignment="Center"/>
                    
                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" Background="#F0F4F8" Cursor="Hand" VerticalAlignment="Center">
                        <Border.ToolTip>View Profile</Border.ToolTip>
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick" Command="{Binding OpenProfileCommand}"/>
                        </Border.InputBindings>
                        
                        <Grid>
                            <!-- Fallback default user icon -->
                            <materialDesign:PackIcon Kind="Account" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Ft.Brush.Muted}"/>
                            
                            <!-- Real image overlay (transparent if ProfileImagePath is null) -->
                            <Ellipse>
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding ProfileImagePath}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 2. Main Content (Stacked Vertically) -->
            <StackPanel>

                <!-- 3. Top Row -> Daily Goal Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Daily Goal" FontWeight="SemiBold" FontSize="18" Foreground="{StaticResource Ft.Brush.Heading}" Margin="0,0,0,20" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        
                        <Grid Width="160" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10">
                            <!-- Background Ring -->
                            <Ellipse Width="160" Height="160" Stroke="#E2E8F0" StrokeThickness="8"/>
                            
                            <!-- 75% Progress Ring WPF Path -->
                            <!-- Radius = 80, Stroke = 8, Inner Radius for path = 76. Start at (80,4) End at (4,80) (approx 270deg) -->
                            <Path x:Name="ProgressArc" Width="160" Height="160" Stretch="None" Stroke="{StaticResource Ft.Brush.Primary}" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="80,4">
                                            <ArcSegment Size="76,76" IsLargeArc="True" SweepDirection="Clockwise" Point="4,80"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>

                            <!-- Inner Text perfectly centered by Grid -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="75%" FontSize="36" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Primary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Completed" FontSize="13" FontWeight="Medium" Foreground="{StaticResource Ft.Brush.Muted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 4. Bottom Row -> 4 Stats Grid (2x2) -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Calories -->
                    <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Calories" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Muted}" VerticalAlignment="Center"/>
                                <TextBlock Text="🔥" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="1200/2000" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}"/>
                            <ProgressBar Value="60" Height="8" Margin="0,16,0,0" Foreground="#FF7043" Background="#F1F5F9" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Water -->
                    <Border Grid.Row="0" Grid.Column="1" Margin="10,0,0,10" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Water" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Muted}" VerticalAlignment="Center"/>
                                <TextBlock Text="💧" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="6/8 Glasses" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}"/>
                            <ProgressBar Value="75" Height="8" Margin="0,16,0,0" Foreground="#00B4D8" Background="#F1F5F9" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: Exercises -->
                    <Border Grid.Row="1" Grid.Column="0" Margin="0,10,10,0" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Exercises" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Muted}" VerticalAlignment="Center"/>
                                <TextBlock Text="💪" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="30/60 min" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}"/>
                            <ProgressBar Value="50" Height="8" Margin="0,16,0,0" Foreground="#20C997" Background="#F1F5F9" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 4: Meals -->
                    <Border Grid.Row="1" Grid.Column="1" Margin="10,10,0,0" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Meals" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Muted}" VerticalAlignment="Center"/>
                                <TextBlock Text="🍽" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="3/5" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}"/>
                            <ProgressBar Value="60" Height="8" Margin="0,16,0,0" Foreground="#F6AD55" Background="#F1F5F9" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
