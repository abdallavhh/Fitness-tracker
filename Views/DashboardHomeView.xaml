<UserControl x:Class="FitnessTracker.Views.DashboardHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:m="clr-namespace:FitnessTracker.Models"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,30,40,30" MaxWidth="1200" HorizontalAlignment="Stretch">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Greeting}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding DateDisplay}" FontSize="14" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1" Width="48" Height="48" Padding="0"
                        Background="{StaticResource Ft.Brush.Card}" BorderBrush="{StaticResource Ft.Brush.Border}" BorderThickness="1"
                        Cursor="Hand" Command="{Binding OpenProfileCommand}" ToolTip="Profile" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="24" Effect="{StaticResource Ft.Shadow.Soft}">
                                <materialDesign:PackIcon Kind="Account" Width="26" Height="26"
                                                         Foreground="{StaticResource Ft.Brush.Primary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Daily goal: full width on small screens, capped on large -->
            <Border Style="{StaticResource Ft.Card}" HorizontalAlignment="Stretch" MaxWidth="480" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Daily Goal" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,16"/>
                    <Grid Width="180" Height="180" HorizontalAlignment="Center" Margin="0,8,0,16">
                        <Ellipse Width="180" Height="180" Stroke="#E5E7EB" StrokeThickness="12" Fill="Transparent"/>
                        <Canvas Width="180" Height="180">
                            <Path x:Name="ProgressArc" Stroke="{StaticResource Ft.Brush.Primary}" StrokeThickness="12"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                        </Canvas>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DailyGoalPercentText}" Style="{StaticResource HighlightNumberStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Completed" Style="{StaticResource SubtextLabelStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stat cards: 2×2 grid reflows evenly at any width -->
            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,8">
                <!-- Calories -->
                <Border Style="{StaticResource Ft.Card}" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Calories" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Border HorizontalAlignment="Right" Width="40" Height="40" CornerRadius="8" Background="#FEF3C7">
                                <materialDesign:PackIcon Kind="Fire" Width="22" Height="22" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CaloriesRatioText}" Style="{StaticResource HighlightNumberTealStyle}" TextWrapping="Wrap"/>
                        <ProgressBar Value="{Binding CaloriesProgress, Mode=OneWay}" Maximum="100" Height="6" Margin="0,14,0,0"
                                     Foreground="{StaticResource Ft.Brush.Primary}" Background="#F3F4F6" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Water -->
                <Border Style="{StaticResource Ft.Card}" Margin="8,0,0,8" MinWidth="140">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Water" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Width="40" Height="40" CornerRadius="8" Background="#E0F2FE">
                                <materialDesign:PackIcon Kind="CupWater" Width="22" Height="22" Foreground="#0EA5E9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding WaterRatioText}" Style="{StaticResource HighlightNumberStyle}" Foreground="#0EA5E9" TextWrapping="Wrap"/>
                        <ProgressBar Value="{Binding WaterProgress, Mode=OneWay}" Maximum="100" Height="6" Margin="0,14,0,0"
                                     Foreground="#0EA5E9" Background="#F3F4F6" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Exercises -->
                <Border Style="{StaticResource Ft.Card}" Margin="0,0,8,0" MinWidth="140">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Exercises" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Width="40" Height="40" CornerRadius="8" Background="#D1FAE5">
                                <materialDesign:PackIcon Kind="Dumbbell" Width="22" Height="22" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding ExerciseRatioText}" Style="{StaticResource HighlightNumberStyle}" Foreground="#10B981" TextWrapping="Wrap"/>
                        <ProgressBar Value="{Binding ExerciseProgress, Mode=OneWay}" Maximum="100" Height="6" Margin="0,14,0,0"
                                     Foreground="#10B981" Background="#F3F4F6" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Meals -->
                <Border Style="{StaticResource Ft.Card}" Margin="8,0,0,0" MinWidth="140">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Meals" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Width="40" Height="40" CornerRadius="8" Background="#FFEDD5">
                                <materialDesign:PackIcon Kind="FoodVariant" Width="22" Height="22" Foreground="#F97316" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding MealsRatioText}" Style="{StaticResource HighlightNumberStyle}" Foreground="#F97316" TextWrapping="Wrap"/>
                        <ProgressBar Value="{Binding MealsProgress, Mode=OneWay}" Maximum="100" Height="6" Margin="0,14,0,0"
                                     Foreground="#F97316" Background="#F3F4F6" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Activity -->
            <Border Style="{StaticResource Ft.Card}" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="Today's Activity" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Ft.Brush.Heading}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding ActivityItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:ActivityFeedItemModel}">
                                <Border CornerRadius="8" Background="{StaticResource Ft.Brush.SurfaceSubtle}" Padding="14" Margin="0,0,0,10"
                                        BorderBrush="{StaticResource Ft.Brush.BorderLight}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8" Background="{Binding AccentBg}">
                                            <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="14,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Heading}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="12" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding KcalLabel}" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
