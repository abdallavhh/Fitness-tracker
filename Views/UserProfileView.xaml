<UserControl x:Class="FitnessTracker.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <UserControl.Resources>
        <Style x:Key="ProfileValueTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource Ft.Brush.Heading}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="IsReadOnly" Value="False"/>
                    <Setter Property="Padding" Value="8,4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="28">
        <Border Background="White"
                CornerRadius="16"
                Padding="30"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="#222222"
                                  Opacity="0.05"
                                  BlurRadius="25"
                                  ShadowDepth="5"
                                  Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="36"
                            Height="36"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding GoBackCommand}"
                            Cursor="Hand"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left">
                        <materialDesign:PackIcon Kind="ArrowLeft"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="#212121"/>
                    </Button>

                    <Grid Grid.Column="1" Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <!-- Background and Fallback Icon -->
                        <Ellipse Fill="#EAF4FF" Stroke="#E5E7EB" StrokeThickness="1"/>
                        <materialDesign:PackIcon Kind="Account" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Ft.Brush.Muted}"/>
                        
                        <!-- Real profile image overlay -->
                        <Ellipse>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ProfileImagePath}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Upload Photo Floating Action Button Overlay -->
                        <Border Width="28" Height="28" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                Cursor="Hand" ToolTip="Upload Picture">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="1" BlurRadius="2"/>
                            </Border.Effect>
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding UploadImageCommand}"/>
                            </Border.InputBindings>
                            <materialDesign:PackIcon Kind="CameraPlus" Width="14" Height="14" Foreground="#4A5568" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,0,0,0">
                        <Button Content="Edit Profile"
                                Style="{StaticResource App.Styles.Button.Ghost.Flat}"
                                Command="{Binding EditCommand}"
                                HorizontalAlignment="Right"
                                Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVis}}"/>

                        <Button Content="Save"
                                Style="{StaticResource App.Styles.Button.Primary}"
                                Command="{Binding SaveCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,4,0,0"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,40,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Gender:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Age:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Height:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HeightCm, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Weight:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding WeightKg, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Medical Condition:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding MedicalCondition, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Dietary Preference:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding DietaryPreference, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Target Weight:" Foreground="{StaticResource Ft.Brush.Muted}" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding TargetWeightKg, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ProfileValueTextBoxStyle}" Margin="0,0,0,16"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
