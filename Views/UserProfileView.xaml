<UserControl x:Class="FitnessTracker.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="0">
        <StackPanel MaxWidth="600" Margin="40,30,40,30" HorizontalAlignment="Stretch">
            <StackPanel Margin="0,0,0,20">
                <Button HorizontalAlignment="Left" Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding GoBackCommand}" ToolTip="Back">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                </Button>
                <Button HorizontalAlignment="Stretch" Margin="0,10,0,0" Style="{StaticResource Ft.Btn.Primary}"
                        Padding="16,10" Content="Save profile" Command="{Binding SaveProfileCommand}"/>
            </StackPanel>

            <Border Style="{StaticResource Ft.Card}" HorizontalAlignment="Center" Padding="24" Margin="0,0,0,24">
                <Border Width="96" Height="96" CornerRadius="48" Background="{StaticResource Ft.Brush.SurfaceSubtle}"
                        BorderBrush="{StaticResource Ft.Brush.Border}" BorderThickness="1">
                    <materialDesign:PackIcon Kind="Account" Width="48" Height="48" Foreground="{StaticResource Ft.Brush.Label}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Border>

            <Border Style="{StaticResource Ft.Card}">
                <StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Username" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Gender" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Age" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Height (cm)" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding HeightCm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Weight (kg)" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding WeightKg, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Medical condition" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding MedicalCondition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Dietary preference" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding DietaryPreference, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Target weight (kg)" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding TargetWeightKg, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
