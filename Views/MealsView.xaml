<UserControl x:Class="FitnessTracker.Views.MealsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:m="clr-namespace:FitnessTracker.Models"
             xmlns:converters="clr-namespace:FitnessTracker.Converters"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}">

    <UserControl.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrush"/>
    </UserControl.Resources>

    <Grid Margin="40,30,40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Meals"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource Ft.Brush.Heading}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="+ Add Meal"
                        Style="{StaticResource App.Styles.Button.Primary}"
                        Command="{Binding AddMealCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding MealsView}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:MealEntryModel}">
                        <Border Style="{StaticResource SoftShadowListItem}" Padding="14" Margin="0,0,0,10" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="8"
                                        Background="{Binding TileBg, Converter={StaticResource HexToBrush}}">
                                    <TextBlock Text="{Binding Icon}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ft.Brush.Heading}"/>
                                    <TextBlock FontSize="14" Foreground="{StaticResource Ft.Brush.Primary}" Margin="0,4,0,0"
                                               Text="{Binding Calories, StringFormat={}{0} Cal}"/>
                                </StackPanel>
                                <materialDesign:PackIcon Grid.Column="2" Kind="ChevronRight" VerticalAlignment="Center" Foreground="{StaticResource Ft.Brush.Label}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource Ft.SearchBar}" Margin="0,16,0,0">
            <TextBox materialDesign:HintAssist.Hint="Search Meal..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     BorderThickness="0" Background="Transparent"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
        </Border>
    </Grid>
</UserControl>
