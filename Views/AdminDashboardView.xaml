<UserControl x:Class="FitnessTracker.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource Ft.Brush.Page}"
             FontFamily="{StaticResource Ft.Font.App}"
             SizeChanged="AdminDashboardView_OnSizeChanged">

    <ScrollViewer x:Name="RootScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="0">
        <!-- Global main-area inset: separates content from sidebar + window edges -->
        <Grid Margin="40,30,40,30"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              MinWidth="300"
              MinHeight="400">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: title + subtitle -->
            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20">
                <TextBlock Text="Admin Dashboard"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource Ft.Brush.Heading}"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Platform overview"
                           FontSize="14"
                           Foreground="{StaticResource Ft.Brush.Label}"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Primary action -->
            <Button x:Name="BtnAddUser"
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    MinHeight="44"
                    Style="{StaticResource Ft.Btn.Primary}"
                    Content="+ Add User"
                    Command="{Binding AddUserCommand}"/>

            <!-- KPI row -->
            <WrapPanel Grid.Row="2"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,20"
                       Orientation="Horizontal">
                <Border Style="{StaticResource Ft.Card}" Margin="0,0,10,10" MinWidth="200" MinHeight="120" HorizontalAlignment="Stretch">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="Users" FontSize="13" Foreground="{StaticResource Ft.Brush.Label}"/>
                            <TextBlock Text="{Binding UserCount}" FontSize="36" FontWeight="Bold" Foreground="#1E88E5" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding UsersDelta, StringFormat=▲ {0}% vs last month}" FontSize="12" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Width="52" Height="52" CornerRadius="12" Background="#E3F2FD" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="28" Height="28" Foreground="#1E88E5"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Style="{StaticResource Ft.Card}" Margin="0,0,10,10" MinWidth="200" MinHeight="120" HorizontalAlignment="Stretch">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="Meals" FontSize="13" Foreground="{StaticResource Ft.Brush.Label}"/>
                            <TextBlock Text="{Binding MealCount}" FontSize="36" FontWeight="Bold" Foreground="#F97316" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding MealsDelta, StringFormat=▲ {0}% vs last month}" FontSize="12" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Width="52" Height="52" CornerRadius="12" Background="#FFEDD5" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="FoodVariant" Width="28" Height="28" Foreground="#F97316"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Style="{StaticResource Ft.Card}" Margin="0,0,0,10" MinWidth="200" MinHeight="120" HorizontalAlignment="Stretch">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="Exercises" FontSize="13" Foreground="{StaticResource Ft.Brush.Label}"/>
                            <TextBlock Text="{Binding ExerciseCount}" FontSize="36" FontWeight="Bold" Foreground="#10B981" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding ExercisesDelta, StringFormat=▲ {0}% vs last month}" FontSize="12" Foreground="{StaticResource Ft.Brush.Label}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Width="52" Height="52" CornerRadius="12" Background="#D1FAE5" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="Dumbbell" Width="28" Height="28" Foreground="#10B981"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </WrapPanel>

            <!-- Monthly Activity: single card (title + chart) with same soft shadow as KPI cards -->
            <Border Grid.Row="3"
                    Style="{StaticResource SoftCardStyle}"
                    Background="White"
                    CornerRadius="12"
                    Padding="24"
                    HorizontalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Stretch">
                    <TextBlock Text="Monthly Activity"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource Ft.Brush.Heading}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"/>
                    <Border Background="{StaticResource Ft.Brush.SurfaceSubtle}"
                            BorderBrush="{StaticResource Ft.Brush.BorderLight}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            HorizontalAlignment="Stretch"
                            SnapsToDevicePixels="True">
                        <lvc:CartesianChart x:Name="MonthlyChart" Series="{Binding MonthlySeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                            LegendPosition="Hidden" TooltipPosition="Hidden"
                                            MinHeight="180"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
