<Window x:Class="FitnessTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:FitnessTracker.ViewModels"
        Title="Fitness &amp; Health Tracker"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="SingleBorderWindow"
        Height="860"
        Width="1380"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.AppBackground}"
        FontFamily="{StaticResource Ft.Font.App}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeChanged="MainWindow_OnSizeChanged">

    <Window.Resources>
        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Ft.Brush.SidebarText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Margin" Value="14,3"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource NavKeyActive}">
                            <Binding Path="DataContext.ActiveNavKey" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource Brush.SidebarActive}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}, FallbackValue=Visible}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="{StaticResource Brush.SidebarNavy}"
                    Style="{StaticResource SoftShadowSidebar}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="20,24,20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="52"
                                Height="52"
                                CornerRadius="14"
                                Background="#22FFFFFF">
                            <materialDesign:PackIcon Kind="HeartPulse"
                                                     Foreground="White"
                                                     Width="26"
                                                     Height="26"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="FITNESS"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="TRACKER"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Brush.PrimaryTeal}"/>
                        </StackPanel>
                    </Grid>

                    <Button DockPanel.Dock="Bottom"
                            Margin="14,8,14,24"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource SidebarNavButton}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Logout"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="{StaticResource Brush.DangerRed}"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Logout"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.DangerRed}"
                                       FontSize="15"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,18">
                            <Border Visibility="{Binding ShowAdminShell, Converter={StaticResource BoolToVis}}"
                                    Background="#26FFFFFF"
                                    CornerRadius="10"
                                    Margin="14,4,14,12"
                                    Padding="10,7">
                                <TextBlock Text="ADMIN"
                                           HorizontalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           Foreground="{StaticResource Brush.PrimaryTeal}"/>
                            </Border>

                            <ItemsControl Visibility="{Binding ShowUserShell, Converter={StaticResource BoolToVis}}"
                                          ItemsSource="{Binding UserNavItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SidebarNavItemVm}">
                                        <Button Style="{StaticResource SidebarNavButton}"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Key}"
                                                Tag="{Binding Key}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                         Width="18"
                                                                         Height="18"
                                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                         VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           Style="{StaticResource Fds.Text.SidebarNav}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl Visibility="{Binding ShowAdminShell, Converter={StaticResource BoolToVis}}"
                                          ItemsSource="{Binding AdminNavItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SidebarNavItemVm}">
                                        <Button Style="{StaticResource SidebarNavButton}"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Key}"
                                                Tag="{Binding Key}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                         Width="18"
                                                                         Height="18"
                                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                         VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           Style="{StaticResource Fds.Text.SidebarNav}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Rectangle x:Name="NavScrim"
                           Fill="#66000000"
                           Visibility="Collapsed"
                           Panel.ZIndex="2"
                           MouseLeftButtonDown="NavScrim_OnMouseDown"/>
                <Grid Panel.ZIndex="1" Background="{StaticResource Brush.AppBackground}">
                    <ContentControl x:Name="MainContentArea"
                                    Content="{Binding CurrentView}"
                                    Margin="20"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"/>
                </Grid>
            </Grid>
        </Grid>

        <ContentControl Content="{Binding Login}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVis}, FallbackValue=Collapsed}"/>
    </Grid>
</Window>