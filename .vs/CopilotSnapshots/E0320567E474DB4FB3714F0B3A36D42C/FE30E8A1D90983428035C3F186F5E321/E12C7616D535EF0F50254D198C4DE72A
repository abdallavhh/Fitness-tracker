using System;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;
using System.Windows.Shapes;

namespace FitnessTracker
{
    /// <summary>
    /// DashboardView: User's daily overview.
    /// Key feature: custom circular progress arc drawn via PathGeometry.
    /// </summary>
    public partial class DashboardView : UserControl
    {
        // ─── Configuration ────────────────────────────────────────────────
        private const double ArcCenterX   = 90;   // Canvas center X (180 / 2)
        private const double ArcCenterY   = 90;   // Canvas center Y (180 / 2)
        private const double ArcRadius    = 82;   // Slightly inside the 16px stroke ring (90 - 8)
        private const double GoalPercent  = 0.75; // 75% complete

        public DashboardView()
        {
            InitializeComponent();
            Loaded += OnLoadedAsync;
        }

        // ──────────────────────────────────────────────────────────────────
        //  ON LOADED (ASYNC) — Set dynamic values after XAML tree is ready
        // ──────────────────────────────────────────────────────────────────
        private async void OnLoadedAsync(object sender, RoutedEventArgs e)
        {
            // Run initialization on background thread to keep UI responsive
            await Task.Run(() => InitializeDashboard());
        }

        private void InitializeDashboard()
        {
            // This runs on a background thread
            System.Threading.Thread.Sleep(100); // Simulate data loading

            // Update UI on dispatcher thread
            Dispatcher.Invoke(() =>
            {
                // Set date greeting
                DateText.Text = DateTime.Now.ToString("dddd, MMMM d, yyyy");

                // Draw the circular progress arc
                DrawProgressArc(ProgressArc, GoalPercent);
            });
        }

        // ──────────────────────────────────────────────────────────────────
        //  DRAW CIRCULAR ARC
        //  Uses PathGeometry with ArcSegment to draw a partial circle.
        //  angle=0 is at the top (12 o'clock), sweeps clockwise.
        // ──────────────────────────────────────────────────────────────────
        public static void DrawProgressArc(Path arcPath, double percent)
        {
            // Clamp to avoid degenerate full-circle (360° causes WPF issues)
            percent = Math.Max(0.001, Math.Min(0.999, percent));

            double sweepAngle = percent * 360.0;

            // Start point: top of circle (12 o'clock)
            var startPoint = GetPointOnCircle(ArcCenterX, ArcCenterY, ArcRadius, -90);
            // End point: swept clockwise by sweepAngle degrees
            var endPoint   = GetPointOnCircle(ArcCenterX, ArcCenterY, ArcRadius, -90 + sweepAngle);

            bool isLargeArc = sweepAngle > 180;

            var arcSegment = new ArcSegment
            {
                Point          = endPoint,
                Size           = new Size(ArcRadius, ArcRadius),
                SweepDirection = SweepDirection.Clockwise,
                IsLargeArc     = isLargeArc
            };

            var pathFigure = new PathFigure
            {
                StartPoint = startPoint,
                IsClosed   = false
            };
            pathFigure.Segments.Add(arcSegment);

            var geometry = new PathGeometry();
            geometry.Figures.Add(pathFigure);

            arcPath.Data = geometry;
        }

        // ──────────────────────────────────────────────────────────────────
        //  HELPER: Polar → Cartesian coordinate conversion
        // ──────────────────────────────────────────────────────────────────
        private static Point GetPointOnCircle(double cx, double cy, double r, double angleDeg)
        {
            double rad = angleDeg * Math.PI / 180.0;
            return new Point(cx + r * Math.Cos(rad), cy + r * Math.Sin(rad));
        }

        // ──────────────────────────────────────────────────────────────────
        //  PUBLIC UPDATE METHOD
        //  Call this when binding real data: DashboardView.UpdateGoal(0.83);
        // ──────────────────────────────────────────────────────────────────
        public void UpdateGoal(double percentComplete)
        {
            DrawProgressArc(ProgressArc, percentComplete);
            ProgressPercent.Text = $"{(int)(percentComplete * 100)}%";
        }
    }
}
