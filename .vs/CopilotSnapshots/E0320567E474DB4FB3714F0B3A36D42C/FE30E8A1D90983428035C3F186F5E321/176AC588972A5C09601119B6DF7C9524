using System;
using System.Collections.ObjectModel;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;

namespace FitnessTracker
{
    // ══════════════════════════════════════════════════════════════════
    //  DATA MODEL: UserRecord
    //  Represents one row in the Manage Users DataGrid.
    // ══════════════════════════════════════════════════════════════════
    public class UserRecord
    {
        public int    Id       { get; set; }
        public string Username { get; set; } = string.Empty;
        public string Email    { get; set; } = string.Empty;
        public string Status   { get; set; } = "Active";

        // Derived: initials for the avatar circle
        public string Initials => Username.Length >= 2
            ? Username[..2].ToUpper()
            : Username.ToUpper();

        // Status badge colors (bound in XAML)
        public Brush StatusBackground => Status switch
        {
            "Active"   => new SolidColorBrush(Color.FromRgb(0xF0, 0xFF, 0xF4)),
            "Inactive" => new SolidColorBrush(Color.FromRgb(0xFF, 0xF5, 0xF5)),
            _          => new SolidColorBrush(Color.FromRgb(0xEE, 0xF2, 0xFF))
        };

        public Brush StatusForeground => Status switch
        {
            "Active"   => new SolidColorBrush(Color.FromRgb(0x38, 0xA1, 0x69)),
            "Inactive" => new SolidColorBrush(Color.FromRgb(0xFC, 0x81, 0x81)),
            _          => new SolidColorBrush(Color.FromRgb(0x76, 0x5E, 0xE3))
        };
    }

    // ══════════════════════════════════════════════════════════════════
    //  CODE-BEHIND: AdminDashboardView
    // ══════════════════════════════════════════════════════════════════
    public partial class AdminDashboardView : UserControl
    {
        // Observable collection for two-way DataGrid binding
        private ObservableCollection<UserRecord> _users = new();

        public AdminDashboardView()
        {
            InitializeComponent();
            Loaded += OnLoadedAsync;
        }

        // ─── ON LOADED (ASYNC) ────────────────────────────────────────────
        private async void OnLoadedAsync(object sender, RoutedEventArgs e)
        {
            AdminDateText.Text = DateTime.Now.ToString("dddd, MMMM d, yyyy");
            await LoadSampleUsersAsync();
        }

        // ─── LOAD SAMPLE DATA (ASYNC) ─────────────────────────────────────
        private async Task LoadSampleUsersAsync()
        {
            // Show loading state
            if (UsersGrid != null)
            {
                UsersGrid.Opacity = 0.5;
                UsersGrid.IsEnabled = false;
            }

            try
            {
                // Simulate async data loading on background thread
                _users = await Task.Run(() => CreateSampleUsers());

                // Update UI on dispatcher thread
                UsersGrid.ItemsSource = _users;
            }
            finally
            {
                // Clear loading state
                if (UsersGrid != null)
                {
                    UsersGrid.Opacity = 1.0;
                    UsersGrid.IsEnabled = true;
                }
            }
        }

        // ─── CREATE SAMPLE DATA ───────────────────────────────────────────
        private static ObservableCollection<UserRecord> CreateSampleUsers()
        {
            // Simulate network delay (comment out in production)
            System.Threading.Thread.Sleep(300);

            return new ObservableCollection<UserRecord>
            {
                new() { Id = 1, Username = "user01", Email = "user01@gmail.com", Status = "Active"   },
                new() { Id = 2, Username = "user02", Email = "user02@gmail.com", Status = "Active"   },
                new() { Id = 3, Username = "user03", Email = "user03@gmail.com", Status = "Inactive" },
                new() { Id = 4, Username = "user04", Email = "user04@gmail.com", Status = "Active"   },
            };
        }

        // ─── EDIT BUTTON CLICK ────────────────────────────────────────
        private void EditUser_Click(object sender, RoutedEventArgs e)
        {
            if (sender is Button btn && btn.Tag is int userId)
            {
                // TODO: Open an Edit User dialog/flyout.
                // For now, a confirmation message box:
                MessageBox.Show(
                    $"Edit user with ID: {userId}\n\n(Replace this with your Edit User dialog.)",
                    "Edit User",
                    MessageBoxButton.OK,
                    MessageBoxImage.Information);
            }
        }

        // ─── DELETE BUTTON CLICK ──────────────────────────────────────
        private void DeleteUser_Click(object sender, RoutedEventArgs e)
        {
            if (sender is Button btn && btn.Tag is int userId)
            {
                var confirm = MessageBox.Show(
                    $"Are you sure you want to delete user ID {userId}?",
                    "Confirm Delete",
                    MessageBoxButton.YesNo,
                    MessageBoxImage.Warning);

                if (confirm == MessageBoxResult.Yes)
                {
                    // Remove from the observable collection → DataGrid updates automatically
                    var user = _users.FirstOrDefault(u => u.Id == userId);
                    if (user is not null)
                        _users.Remove(user);
                }
            }
        }
    }
}

// ── Extension helper (avoids a LINQ import conflict in older .NET) ──
file static class LinqHelper
{
    public static T? FirstOrDefault<T>(this System.Collections.ObjectModel.ObservableCollection<T> col, Func<T, bool> predicate)
    {
        foreach (var item in col)
            if (predicate(item)) return item;
        return default;
    }
}
