<UserControl x:Class="FitnessTracker.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F9F6"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000" Opacity="0.04"
                          BlurRadius="24" ShadowDepth="6" Direction="270"/>

        <!-- ─── Admin Summary Card ─────────────────────────── -->
        <Style x:Key="AdminCard" TargetType="Border">
            <Setter Property="Background"   Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding"      Value="24"/>
            <Setter Property="Effect"       Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ─── DataGrid Style ────────────────────────────– -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="RowBackground"           Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
            <Setter Property="VerticalGridLinesBrush"  Value="Transparent"/>
            <Setter Property="HeadersVisibility"       Value="Column"/>
            <Setter Property="AutoGenerateColumns"     Value="False"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="CanUserDeleteRows"       Value="False"/>
            <Setter Property="CanUserReorderColumns"   Value="False"/>
            <Setter Property="CanUserResizeRows"       Value="False"/>
            <Setter Property="SelectionMode"           Value="Single"/>
            <Setter Property="FontSize"                Value="14"/>
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="RowHeight"               Value="60"/>
        </Style>

        <!-- ─── DataGrid Column Header Style ─────────────── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#F8FAFC"/>
            <Setter Property="Foreground"  Value="#6B7280"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="16,16"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>

        <!-- ─── DataGrid Cell Style ──────────────────────── -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D1FAE5"/>
                    <Setter Property="Foreground" Value="#111827"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Edit Button ──────────────────────────────── -->
        <Style x:Key="EditBtn" TargetType="Button">
            <Setter Property="Background"      Value="#D1FAE5"/>
            <Setter Property="Foreground"      Value="#00A884"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00A884"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Delete Button ────────────────────────────── -->
        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Background"      Value="#FEE2E2"/>
            <Setter Property="Foreground"      Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ─── HEADER ───────────────────────────────────── -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Admin Dashboard"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock x:Name="AdminDateText"
                               FontSize="14" Foreground="#6B7280"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Add User Button -->
                <Button Grid.Column="1"
                        Content="+ Add User"
                        Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="24,14">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#00A884" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#008C6E" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ─── TOP SUMMARY CARDS ─────────────────────── -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Users Card -->
                <Border Grid.Column="0"
                        Style="{StaticResource AdminCard}"
                        Margin="0,0,24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total Users"
                                       FontSize="14" Foreground="#6B7280"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="120"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="#0EA5E9"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="▲ 12%" FontSize="13"
                                           Foreground="#10B981" FontWeight="SemiBold"/>
                                <TextBlock Text=" vs last month" FontSize="13"
                                           Foreground="#9CA3AF"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="60" Height="60"
                                CornerRadius="20"
                                Background="#E0F2FE"
                                VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Meals Card -->
                <Border Grid.Column="1"
                        Style="{StaticResource AdminCard}"
                        Margin="0,0,24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total Meals"
                                       FontSize="14" Foreground="#6B7280"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="340"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="#F59E0B"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="▲ 8%" FontSize="13"
                                           Foreground="#10B981" FontWeight="SemiBold"/>
                                <TextBlock Text=" vs last month" FontSize="13"
                                           Foreground="#9CA3AF"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="60" Height="60"
                                CornerRadius="20"
                                Background="#FEF3C7"
                                VerticalAlignment="Center">
                            <TextBlock Text="🍽" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Exercises Card -->
                <Border Grid.Column="2"
                        Style="{StaticResource AdminCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total Exercises"
                                       FontSize="14" Foreground="#6B7280"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="220"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="#10B981"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="▲ 18%" FontSize="13"
                                           Foreground="#10B981" FontWeight="SemiBold"/>
                                <TextBlock Text=" vs last month" FontSize="13"
                                           Foreground="#9CA3AF"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="60" Height="60"
                                CornerRadius="20"
                                Background="#D1FAE5"
                                VerticalAlignment="Center">
                            <TextBlock Text="💪" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── BOTTOM SECTION: Bar Chart + User Table ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Monthly Activity Bar Chart -->
                <Border Grid.Column="0"
                        Style="{StaticResource AdminCard}"
                        Margin="0,0,24,0">
                    <StackPanel>
                        <TextBlock Text="Monthly Activity"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#111827" Margin="0,0,0,24"/>

                        <!-- Custom bar chart drawn with Rectangles -->
                        <Grid Height="200" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="32" Height="100" CornerRadius="8,8,0,0" Background="#99E8DE"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="32" Height="130" CornerRadius="8,8,0,0" Background="#99E8DE"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="32" Height="80" CornerRadius="8,8,0,0" Background="#99E8DE"/>
                            </StackPanel>
                            <!-- Peak Month -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="32" Height="180" CornerRadius="8,8,0,0" Background="#00A884"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="32" Height="120" CornerRadius="8,8,0,0" Background="#99E8DE"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="32" Height="150" CornerRadius="8,8,0,0" Background="#99E8DE"/>
                            </StackPanel>
                        </Grid>

                        <!-- Axis labels -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Jan" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Feb" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Mar" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Apr" FontSize="13" Foreground="#00A884" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="May" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="Jun" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Manage Users Table -->
                <Border Grid.Column="1"
                        Style="{StaticResource AdminCard}">
                    <StackPanel>
                        <!-- Table header -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Manage Users"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#111827"/>
                            <!-- Search box -->
                            <Border Grid.Column="1"
                                    CornerRadius="12"
                                    Background="#F8FAFC"
                                    Padding="16,10"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="14"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBox x:Name="SearchBox"
                                             Width="160"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="14"
                                             Foreground="#4A5568"
                                             VerticalContentAlignment="Center">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- DataGrid -->
                        <DataGrid x:Name="UsersGrid"
                                  Style="{StaticResource ModernDataGrid}"
                                  MaxHeight="360"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <!-- ID -->
                                <DataGridTextColumn Header="ID"
                                                    Binding="{Binding Id}"
                                                    Width="70"
                                                    IsReadOnly="True"/>

                                <!-- Avatar + Username -->
                                <DataGridTemplateColumn Header="Username" Width="180" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="4,0">
                                                <Border Width="36" Height="36"
                                                        CornerRadius="18"
                                                        Background="#D1FAE5"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Initials}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="#00A884"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Username}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Email -->
                                <DataGridTextColumn Header="Email"
                                                    Binding="{Binding Email}"
                                                    Width="*"
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Actions -->
                                <DataGridTemplateColumn Header="Actions" Width="160" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="4,0">
                                                <Button Content="Edit"
                                                        Style="{StaticResource EditBtn}"
                                                        Margin="0,0,8,0"
                                                        Click="EditUser_Click"
                                                        Tag="{Binding Id}"/>
                                                <Button Content="Delete"
                                                        Style="{StaticResource DeleteBtn}"
                                                        Click="DeleteUser_Click"
                                                        Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <TextBlock Text="Showing 1–4 of 4 users"
                                       FontSize="13"
                                       Foreground="#9CA3AF"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
