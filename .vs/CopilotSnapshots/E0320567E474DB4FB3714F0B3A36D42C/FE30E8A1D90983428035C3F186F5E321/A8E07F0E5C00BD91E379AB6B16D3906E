using System;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;

namespace FitnessTracker
{
    /// <summary>
    /// LoginView: User authentication screen.
    /// Handles credential validation and navigation to main app.
    /// </summary>
    public partial class LoginView : UserControl
    {
        // Event to notify MainWindow of successful login
        public event EventHandler? LoginSuccessful;

        public LoginView()
        {
            InitializeComponent();
        }

        // ──────────────────────────────────────────────────────────────────
        //  LOGIN BUTTON CLICK HANDLER
        // ──────────────────────────────────────────────────────────────────
        private void LoginButton_Click(object sender, RoutedEventArgs e)
        {
            AttemptLogin();
        }

        // ──────────────────────────────────────────────────────────────────
        //  KEYDOWN HANDLER - Allow Enter to trigger login
        // ──────────────────────────────────────────────────────────────────
        private void InputField_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key == Key.Return)
            {
                AttemptLogin();
                e.Handled = true;
            }
        }

        // ──────────────────────────────────────────────────────────────────
        //  ATTEMPT LOGIN
        //  Validates credentials and raises LoginSuccessful event if valid.
        // ──────────────────────────────────────────────────────────────────
        // ──────────────────────────────────────────────────────────────────
        //  PASSWORD VISIBILITY TOGGLE LOGIC
        // ──────────────────────────────────────────────────────────────────
        private bool _isPasswordVisible = false;
        private bool _isUpdatingPassword = false;

        private void TogglePasswordButton_Click(object sender, RoutedEventArgs e)
        {
            _isPasswordVisible = !_isPasswordVisible;

            if (_isPasswordVisible)
            {
                // Show clear text, hide password mask
                PasswordVisibleBox.Visibility = Visibility.Visible;
                PasswordBox.Visibility = Visibility.Collapsed;

                // Sync text
                _isUpdatingPassword = true;
                PasswordVisibleBox.Text = PasswordBox.Password;
                _isUpdatingPassword = false;

                PasswordVisibleBox.Focus();
                PasswordVisibleBox.Select(PasswordVisibleBox.Text.Length, 0);

                if (TogglePasswordButton.Template.FindName("TogglePasswordIcon", TogglePasswordButton) is TextBlock icon)
                {
                    icon.Text = "🙈"; 
                }
                else if (TogglePasswordButton.Content is TextBlock contentIcon) 
                {
                    contentIcon.Text = "🙈"; 
                }
            }
            else
            {
                // Show mask, hide clear text
                PasswordVisibleBox.Visibility = Visibility.Collapsed;
                PasswordBox.Visibility = Visibility.Visible;

                // Sync text
                _isUpdatingPassword = true;
                PasswordBox.Password = PasswordVisibleBox.Text;
                _isUpdatingPassword = false;

                PasswordBox.Focus();

                if (TogglePasswordButton.Template.FindName("TogglePasswordIcon", TogglePasswordButton) is TextBlock icon)
                {
                    icon.Text = "👁";
                }
                else if (TogglePasswordButton.Content is TextBlock contentIcon) 
                {
                    contentIcon.Text = "👁"; 
                }
            }
        }

        private void PasswordBox_PasswordChanged(object sender, RoutedEventArgs e)
        {
            if (!_isUpdatingPassword)
            {
                _isUpdatingPassword = true;
                PasswordVisibleBox.Text = PasswordBox.Password;
                _isUpdatingPassword = false;
            }
        }

        private void PasswordVisibleBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            if (!_isUpdatingPassword)
            {
                _isUpdatingPassword = true;
                PasswordBox.Password = PasswordVisibleBox.Text;
                _isUpdatingPassword = false;
            }
        }

        private void AttemptLogin()
        {
            string username = UsernameTextBox.Text?.Trim() ?? string.Empty;
            string password = PasswordBox.Password ?? string.Empty;

            // Hide error message by default
            ErrorBorder.Visibility = Visibility.Collapsed;

            // Basic validation
            if (string.IsNullOrEmpty(username) || string.IsNullOrEmpty(password))
            {
                ShowError("Please enter both username and password");
                return;
            }

            // Simple demo credential validation
            // In a real application, validate against a backend API or database
            if (ValidateCredentials(username, password))
            {
                // Clear sensitive data
                UsernameTextBox.Clear();
                PasswordBox.Clear();

                // Notify parent window of successful login
                LoginSuccessful?.Invoke(this, EventArgs.Empty);
            }
            else
            {
                ShowError("Invalid username or password");
                PasswordBox.Clear();
                UsernameTextBox.Focus();
            }
        }

        // ──────────────────────────────────────────────────────────────────
        //  VALIDATE CREDENTIALS
        //  Demo validation logic. Replace with actual authentication.
        // ──────────────────────────────────────────────────────────────────
        private static bool ValidateCredentials(string username, string password)
        {
            // Demo credentials - in production, validate against your backend
            const string DemoUsername = "demo";
            const string DemoPassword = "password";

            return username.Equals(DemoUsername, StringComparison.OrdinalIgnoreCase)
                && password.Equals(DemoPassword);
        }

        // ──────────────────────────────────────────────────────────────────
        //  SHOW ERROR
        //  Displays error message to user.
        // ──────────────────────────────────────────────────────────────────
        private void ShowError(string message)
        {
            ErrorMessage.Text = message;
            ErrorBorder.Visibility = Visibility.Visible;
        }
    }
}
