using System.Windows;
using System.Windows.Input;
using FitnessTracker.ViewModels;

namespace FitnessTracker;

public partial class MainWindow : Window
{
    /// <summary>Below this width the nav column collapses and a compact header + scrim drawer pattern is used.</summary>
    private const double CompactNavBreakpoint = 1000;
    private const double SidebarWidth = 250;

    private bool _mobileNavOpen;
    private MainWindowViewModel? _vm;

    public MainWindow()
    {
        InitializeComponent();
        _vm = new MainWindowViewModel();
        DataContext = _vm;
        _vm.NavigationOccurred += (_, _) => CloseMobileNav();
        _vm.ShellChromeChanged += (_, _) =>
        {
            if (_vm is { IsLoggedIn: false })
                CloseMobileNav();
            ApplyResponsiveLayout();
        };
        Loaded += (_, _) => ApplyResponsiveLayout();
    }

    private void MainWindow_OnSizeChanged(object sender, SizeChangedEventArgs e) => ApplyResponsiveLayout();

    private void TitleBar_OnMouseLeftButtonDown(object sender, MouseButtonEventArgs e)
    {
        if (e.ClickCount == 2)
        {
            ToggleWindowState();
            return;
        }

        DragMove();
    }

    private void MinimizeButton_OnClick(object sender, RoutedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void MaximizeButton_OnClick(object sender, RoutedEventArgs e)
    {
        ToggleWindowState();
    }

    private void CloseButton_OnClick(object sender, RoutedEventArgs e)
    {
        Application.Current.Shutdown();
    }

    private void BtnMenu_OnClick(object sender, RoutedEventArgs e)
    {
        _mobileNavOpen = !_mobileNavOpen;
        ApplyResponsiveLayout();
    }

    private void NavScrim_OnMouseDown(object sender, MouseButtonEventArgs e)
    {
        CloseMobileNav();
        e.Handled = true;
    }

    private void CloseMobileNav()
    {
        _mobileNavOpen = false;
        ApplyResponsiveLayout();
    }

    private void ToggleWindowState()
    {
        WindowState = WindowState == WindowState.Maximized
            ? WindowState.Normal
            : WindowState.Maximized;
    }

    private void ApplyResponsiveLayout()
    {
        if (_vm is not { IsLoggedIn: true })
        {
            MobileHeader.Visibility = Visibility.Collapsed;
            NavScrim.Visibility = Visibility.Collapsed;
            NavColumn.Width = new GridLength(SidebarWidth);
            SidebarPanel.Visibility = Visibility.Visible;
            return;
        }

        bool compact = ActualWidth > 0 && ActualWidth < CompactNavBreakpoint;

        if (!compact)
        {
            _mobileNavOpen = false;
            MobileHeader.Visibility = Visibility.Collapsed;
            NavScrim.Visibility = Visibility.Collapsed;
            NavColumn.Width = new GridLength(SidebarWidth);
            SidebarPanel.Visibility = Visibility.Visible;
            return;
        }

        MobileHeader.Visibility = Visibility.Visible;
        NavColumn.Width = new GridLength(_mobileNavOpen ? SidebarWidth : 0);
        SidebarPanel.Visibility = _mobileNavOpen ? Visibility.Visible : Visibility.Collapsed;
        NavScrim.Visibility = _mobileNavOpen ? Visibility.Visible : Visibility.Collapsed;
    }
}
