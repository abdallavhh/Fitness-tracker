<UserControl x:Class="FitnessTracker.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F9F6"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <DropShadowEffect x:Key="LoginCardShadow"
                          Color="#000000" Opacity="0.06"
                          BlurRadius="32" ShadowDepth="8" Direction="270"/>

        <!-- ─── Emerald Primary Button ───────── -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#00A884"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0,14"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#008C6E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007058"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Modern Input Fields ───────── -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#111827"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                         <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                             <Grid>
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="40" />
                                     <ColumnDefinition Width="*" />
                                 </Grid.ColumnDefinitions>
                                 <TextBlock Text="👤" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="16" />
                                 <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1"
                                               Margin="0,0,16,0"
                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                             </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00A884"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#111827"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="40" />
                                     <ColumnDefinition Width="*" />
                                     <ColumnDefinition Width="40" />
                                 </Grid.ColumnDefinitions>
                                 <TextBlock Text="🔒" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="16" />
                                 <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1"
                                               Margin="0,0,0,0"
                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                 <TextBlock Text="👁" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="14" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00A884"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextLinkStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00A884"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#008C6E"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Center Card Layout to match the Single Screen Aesthetic -->
    <Grid>
        <!-- Background decorative elements optional, keeping clean green tint #F2F9F6 -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#FFFFFF"
                Width="420"
                CornerRadius="24"
                Padding="40,50,40,50"
                Effect="{StaticResource LoginCardShadow}">
            
            <StackPanel>
                <!-- Logo -->
                <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z M12 6c-1.5-2.09-3.76-2.09-4.5-2.09-2.28 0-4.5 1.42-4.5 4.59 0 2.78 2.4 5.86 7.55 10.54L12 20.35l1.45-1.32c5.15-4.68 7.55-7.76 7.55-10.54 0-3.17-2.22-4.59-4.5-4.59-.74 0-3 0-4.5 2.09z"
                      Fill="{StaticResource AccentGreen}"
                      Stretch="Uniform" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                
                <TextBlock Text="FITNESS TRACKER"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#111827"
                           TextAlignment="Center"
                           Margin="0,0,0,8"/>
                
                <TextBlock Text="Login to Your Account"
                           FontSize="15"
                           Foreground="#6B7280"
                           TextAlignment="Center"
                           Margin="0,0,0,32"/>
                
                <!-- Error Message Banner -->
                <Border x:Name="ErrorBorder"
                        Background="#FEE2E2"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorMessage"
                               Foreground="#EF4444"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Inputs -->
                <TextBox x:Name="UsernameTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,16"
                         KeyDown="InputField_KeyDown"/>
                
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBoxStyle}"
                             Margin="0,0,0,24"
                             KeyDown="InputField_KeyDown"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Style="{StaticResource LoginButtonStyle}"
                        Content="Login"
                        Click="LoginButton_Click"
                        Margin="0,0,0,24"/>

                <!-- Links -->
                <TextBlock Text="Forgot Password?" Style="{StaticResource TextLinkStyle}" Margin="0,0,0,12"/>
                <TextBlock Text="Create New Account" Style="{StaticResource TextLinkStyle}"/>

                <!-- Demo Credentials (Subtle) -->
                <Border Background="#F8FAFC"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,32,0,0"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Demo Credentials:"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#00A884"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="user: demo | pass: password"
                                   FontSize="11"
                                   Foreground="#6B7280"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
