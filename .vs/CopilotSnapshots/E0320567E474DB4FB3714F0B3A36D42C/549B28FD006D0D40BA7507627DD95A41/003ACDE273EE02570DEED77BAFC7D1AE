<Application x:Class="FitnessTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FitnessTracker.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Teal"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml"/>
                <ResourceDictionary Source="/Themes/DesignTokens.xaml"/>
                <ResourceDictionary Source="/Themes/ViewDataTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:NavKeyActiveMultiConverter x:Key="NavKeyActive"/>

            <Style TargetType="TextElement">
                <Setter Property="FontFamily" Value="{StaticResource Ft.Font.App}"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource Ft.Font.App}"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource Ft.Font.App}"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource Ft.Font.App}"/>
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="{StaticResource Ft.Font.App}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
