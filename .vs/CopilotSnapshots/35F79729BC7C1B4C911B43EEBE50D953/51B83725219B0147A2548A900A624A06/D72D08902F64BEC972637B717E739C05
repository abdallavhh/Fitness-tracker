<UserControl x:Class="FitnessTracker.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F8F7"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#00897B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0,14"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource CardShadow}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#006B63"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#004D40"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#A7D8D4"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#0F1A2A"/>
            <Setter Property="BorderBrush"     Value="#E0F2F1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00897B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#0F1A2A"/>
            <Setter Property="BorderBrush"     Value="#E0F2F1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00897B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000" Opacity="0.08"
                          BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </UserControl.Resources>

    <Grid Background="#F0F8F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F1A2A">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">
                <Border Width="120" Height="120"
                        Background="#00897B"
                        CornerRadius="24"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32">
                    <TextBlock Text="🏋" FontSize="64"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="FITNESS TRACKER"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="Track your fitness journey and achieve your health goals"
                           Foreground="#B0BEC5"
                           FontSize="16"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           LineHeight="24"/>

                <StackPanel Margin="0,48,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="#26A69A" FontSize="16"
                                   Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Daily activity tracking" Foreground="#B0BEC5" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="#26A69A" FontSize="16"
                                   Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Personal health metrics" Foreground="#B0BEC5" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" Foreground="#26A69A" FontSize="16"
                                   Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Goal setting and progress" Foreground="#B0BEC5" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="60,40">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Welcome Back"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#0F1A2A"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Sign in to your account to continue"
                               FontSize="14"
                               Foreground="#607D8B"
                               Margin="0,0,0,32"/>

                    <Border x:Name="ErrorBorder"
                            Background="#FFEBEE"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessage"
                                   Foreground="#C62828"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Username or Email"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#0F1A2A"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="UsernameTextBox"
                             Style="{StaticResource LoginTextBoxStyle}"
                             Margin="0,0,0,20"
                             KeyDown="InputField_KeyDown"/>

                    <TextBlock Text="Password"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#0F1A2A"
                               Margin="0,0,0,8"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                 Margin="0,0,0,20"
                                 KeyDown="InputField_KeyDown"/>

                    <Grid Margin="0,0,0,32">
                        <CheckBox x:Name="RememberMeCheckBox"
                                  Foreground="#607D8B"
                                  FontSize="13"
                                  VerticalAlignment="Center">
                            <TextBlock Text="Remember me" VerticalAlignment="Center"/>
                        </CheckBox>
                    </Grid>

                    <Button x:Name="LoginButton"
                            Style="{StaticResource LoginButtonStyle}"
                            Content="Sign In"
                            Click="LoginButton_Click"
                            Margin="0,0,0,16"/>

                    <Grid Margin="0,16,0,16" Height="1" Background="#E0F2F1"/>

                    <Border Background="#F1F8F7"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Demo Credentials:"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#004D40"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Username: demo"
                                       FontSize="12"
                                       Foreground="#37474F"
                                       FontFamily="Consolas"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Password: password"
                                       FontSize="12"
                                       Foreground="#37474F"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account? Contact your administrator"
                                   FontSize="12"
                                   Foreground="#607D8B"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
