<UserControl x:Class="FitnessTracker.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F8F7"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- ═══════════════════════════════════════════════════ -->
        <!--            SHARED RESOURCE OVERRIDES               -->
        <!-- ═══════════════════════════════════════════════════ -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000" Opacity="0.06"
                          BlurRadius="18" ShadowDepth="3" Direction="270"/>

        <DropShadowEffect x:Key="TinyShadow"
                          Color="#000000" Opacity="0.04"
                          BlurRadius="8" ShadowDepth="1" Direction="270"/>

        <!-- ─── Summary Card Style ─────────────────────────── -->
        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="16"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="Effect"          Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ─── Card Title Label ───────────────────────────── -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Foreground"   Value="#607D8B"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <!-- ─── Large Value Label ─────────────────────────── -->
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="26"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="#0F1A2A"/>
        </Style>

        <!-- ─── Sub Value Label ───────────────────────────── -->
        <Style x:Key="SubValue" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Foreground"   Value="#B0BEC5"/>
            <Setter Property="Margin"       Value="0,4,0,0"/>
        </Style>

        <!-- ─── Icon Circle Background ───────────────────── -->
        <Style x:Key="IconCircle" TargetType="Border">
            <Setter Property="Width"        Value="44"/>
            <Setter Property="Height"       Value="44"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <!-- ─── Progress Bar Override ────────────────────── -->
        <Style x:Key="TealProgressBar" TargetType="ProgressBar">
            <Setter Property="Height"           Value="8"/>
            <Setter Property="Background"       Value="#E0F2F1"/>
            <Setter Property="Foreground"       Value="#00897B"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Track" CornerRadius="4"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--            SCROLLABLE DASHBOARD CONTENT                 -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">

            <!-- ─── TOP HEADER BAR ──────────────────────────── -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Greeting -->
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="GreetingText"
                               Text="Hello, User 👋"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1A202C"/>
                    <TextBlock x:Name="DateText"
                               FontSize="13"
                               Foreground="#718096"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Profile Avatar -->
                <Border Grid.Column="1"
                        Width="46" Height="46"
                        CornerRadius="23"
                        Background="#00B4D8"
                        Effect="{StaticResource TinyShadow}">
                    <TextBlock Text="JD"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ─── MAIN ROW: DAILY GOAL + QUICK STATS ─────── -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Daily Goal Card -->
                <Border Grid.Column="0"
                        Style="{StaticResource SummaryCard}"
                        Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Daily Goal"
                                   Style="{StaticResource CardTitle}"
                                   FontSize="15"/>

                        <!-- Circular Progress (Canvas-drawn) -->
                        <Grid Width="160" Height="160"
                              HorizontalAlignment="Center"
                              Margin="0,16,0,16">
                            <!-- Background circle -->
                            <Ellipse Width="160" Height="160"
                                     Stroke="#E2E8F0"
                                     StrokeThickness="14"
                                     Fill="Transparent"/>

                            <!-- Progress Arc via PathGeometry -->
                            <Canvas Width="160" Height="160">
                                <Path x:Name="ProgressArc"
                                      Stroke="#00B4D8"
                                      StrokeThickness="14"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"/>
                            </Canvas>

                            <!-- Center Text -->
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="ProgressPercent"
                                           Text="75%"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#00B4D8"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Completed"
                                           FontSize="12"
                                           Foreground="#718096"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Mini legend -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10"
                                     Fill="#00B4D8"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                            <TextBlock Text="Achieved"
                                       FontSize="12"
                                       Foreground="#718096"
                                       Margin="0,0,16,0"/>
                            <Ellipse Width="10" Height="10"
                                     Fill="#E2E8F0"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                            <TextBlock Text="Remaining"
                                       FontSize="12"
                                       Foreground="#718096"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- RIGHT SIDE: 2×2 Stats Grid -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CALORIES Card -->
                    <Border Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource SummaryCard}"
                            Margin="0,0,12,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Calories"
                                           Style="{StaticResource CardTitle}"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource IconCircle}"
                                        Background="#FFF3E0">
                                    <TextBlock Text="🔥" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="1,200"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#FF7043"/>
                            <TextBlock Text="of 2,000 kcal"
                                       Style="{StaticResource SubValue}"/>
                            <ProgressBar Value="60" Maximum="100"
                                         Style="{StaticResource TealProgressBar}"
                                         Foreground="#FF7043"
                                         Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- WATER Card -->
                    <Border Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource SummaryCard}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Water"
                                           Style="{StaticResource CardTitle}"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource IconCircle}"
                                        Background="#E3F2FD">
                                    <TextBlock Text="💧" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="6"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#00B4D8"/>
                            <TextBlock Text="of 8 glasses"
                                       Style="{StaticResource SubValue}"/>
                            <ProgressBar Value="75" Maximum="100"
                                         Style="{StaticResource TealProgressBar}"
                                         Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- EXERCISES Card -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource SummaryCard}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Exercises"
                                           Style="{StaticResource CardTitle}"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource IconCircle}"
                                        Background="#E8F5E9">
                                    <TextBlock Text="💪" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="30"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#20C997"/>
                            <TextBlock Text="of 60 min active"
                                       Style="{StaticResource SubValue}"/>
                            <ProgressBar Value="50" Maximum="100"
                                         Style="{StaticResource TealProgressBar}"
                                         Foreground="#20C997"
                                         Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- MEALS Card -->
                    <Border Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource SummaryCard}"
                            Margin="0,0,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Meals"
                                           Style="{StaticResource CardTitle}"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource IconCircle}"
                                        Background="#FCE4EC">
                                    <TextBlock Text="🍽" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="3"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#F06292"/>
                            <TextBlock Text="of 5 meals logged"
                                       Style="{StaticResource SubValue}"/>
                            <ProgressBar Value="60" Maximum="100"
                                         Style="{StaticResource TealProgressBar}"
                                         Foreground="#F06292"
                                         Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ─── BOTTOM ROW: Activity Timeline + Health Snapshot ─── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Activity List -->
                <Border Grid.Column="0"
                        Style="{StaticResource SummaryCard}"
                        Margin="0,0,16,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Today's Activity"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#1A202C"/>
                            <TextBlock Grid.Column="1"
                                       Text="View All →"
                                       FontSize="12"
                                       Foreground="#00B4D8"
                                       Cursor="Hand"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Activity Item Template (repeated) -->
                        <!-- Running -->
                        <Border CornerRadius="10" Background="#F7FAFC"
                                Padding="14,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        CornerRadius="10"
                                        Background="#E3F2FD">
                                    <TextBlock Text="🏃" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Running"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#1A202C"/>
                                    <TextBlock Text="30 min · Morning"
                                               FontSize="11"
                                               Foreground="#A0AEC0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="−300 kcal"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#20C997"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Cycling -->
                        <Border CornerRadius="10" Background="#F7FAFC"
                                Padding="14,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        CornerRadius="10"
                                        Background="#E8F5E9">
                                    <TextBlock Text="🚴" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Cycling"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#1A202C"/>
                                    <TextBlock Text="45 min · Afternoon"
                                               FontSize="11"
                                               Foreground="#A0AEC0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="−500 kcal"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#20C997"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Breakfast -->
                        <Border CornerRadius="10" Background="#F7FAFC"
                                Padding="14,12" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        CornerRadius="10"
                                        Background="#FFF3E0">
                                    <TextBlock Text="🍳" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Breakfast"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#1A202C"/>
                                    <TextBlock Text="Oats + Eggs · 08:00"
                                               FontSize="11"
                                               Foreground="#A0AEC0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="+300 kcal"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#FF7043"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Health Snapshot Card -->
                <Border Grid.Column="1"
                        Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Text="Health Snapshot"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#1A202C"
                                   Margin="0,0,0,16"/>

                        <!-- Heart Rate -->
                        <Border CornerRadius="10" Background="#FFF5F5"
                                Padding="12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="❤"
                                           FontSize="22"
                                           Foreground="#FC8181"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Heart Rate" FontSize="12"
                                               Foreground="#718096"/>
                                    <TextBlock Text="Normal" FontSize="11"
                                               Foreground="#20C997"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="80 bpm"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="#FC8181"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Blood Sugar -->
                        <Border CornerRadius="10" Background="#F0F9FF"
                                Padding="12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="💧"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Blood Sugar" FontSize="12"
                                               Foreground="#718096"/>
                                    <TextBlock Text="Normal" FontSize="11"
                                               Foreground="#20C997"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="90 mg/dL"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="#00B4D8"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Blood Pressure -->
                        <Border CornerRadius="10" Background="#FFF8E1"
                                Padding="12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🩺"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Blood Pressure" FontSize="12"
                                               Foreground="#718096"/>
                                    <TextBlock Text="Normal" FontSize="11"
                                               Foreground="#20C997"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="120/80"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="#FFB300"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Water -->
                        <Border CornerRadius="10" Background="#F0FFF4"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🫙"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Water Intake" FontSize="12"
                                               Foreground="#718096"/>
                                    <TextBlock Text="On Track" FontSize="11"
                                               Foreground="#20C997"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="2 Liters"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="#20C997"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
