<Window x:Class="FitnessTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FitnessTracker"
        Title="Fitness Tracker" Height="800" Width="1280"
        MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════════ -->
        <!--         MODERN COLOR PALETTE - UPDATED              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="SidebarBg"         Color="#0F1A2A"/>
        <SolidColorBrush x:Key="SidebarHover"      Color="#1A2940"/>
        <SolidColorBrush x:Key="SidebarActive"     Color="#00897B"/>
        <SolidColorBrush x:Key="AccentTeal"        Color="#00897B"/>
        <SolidColorBrush x:Key="AccentGreen"       Color="#26A69A"/>
        <SolidColorBrush x:Key="AccentOrange"      Color="#FF7043"/>
        <SolidColorBrush x:Key="AccentAmber"       Color="#FFB300"/>
        <SolidColorBrush x:Key="MainBg"            Color="#F0F8F7"/>
        <SolidColorBrush x:Key="CardBg"            Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary"       Color="#0F1A2A"/>
        <SolidColorBrush x:Key="TextSecondary"     Color="#607D8B"/>
        <SolidColorBrush x:Key="TextLight"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderLight"       Color="#E0F2F1"/>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--              DROP SHADOW EFFECT                     -->
        <!-- ═══════════════════════════════════════════════════ -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000" Opacity="0.08"
                          BlurRadius="20" ShadowDepth="4" Direction="270"/>

        <DropShadowEffect x:Key="SoftShadow"
                          Color="#000000" Opacity="0.05"
                          BlurRadius="10" ShadowDepth="2" Direction="270"/>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--           SIDEBAR NAV BUTTON STYLE                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#A0AEC0"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Height"           Value="48"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"          Value="20,0,0,0"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="10,2,10,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#2D3748"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#00B4D8"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Nav Button Style -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background"  Value="#2D3748"/>
            <Setter Property="Foreground"  Value="#FFFFFF"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--            PRIMARY ACTION BUTTON STYLE              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#00B4D8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0099B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007A99"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--                  ROOT GRID LAYOUT                       -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Grid x:Name="MainWindow_Root">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar: fixed 250px -->
                <ColumnDefinition Width="250"/>
                <!-- Main content: fills remaining space -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════ -->
            <!--                LEFT SIDEBAR                        -->
            <!-- ══════════════════════════════════════════════════ -->
            <Border x:Name="Sidebar"
                    Grid.Column="0"
                    Background="{StaticResource SidebarBg}"
                    CornerRadius="0,16,16,0">
                <DockPanel>
                    <!-- Logo / Title -->
                    <StackPanel DockPanel.Dock="Top"
                                Margin="20,30,20,30"
                                Orientation="Horizontal">
                        <!-- Dumbbell icon using Unicode -->
                        <Border Width="40" Height="40"
                                Background="#00B4D8"
                                CornerRadius="12">
                            <TextBlock Text="🏋" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="FITNESS"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                            <TextBlock Text="TRACKER"
                                       Foreground="#00B4D8"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Section label -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="MAIN MENU"
                               Foreground="#4A5568"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="20,0,0,8"/>

                    <!-- Logout button pinned to bottom -->
                    <Button DockPanel.Dock="Bottom"
                            x:Name="BtnLogout"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="10,10,10,20"
                            Click="BtnLogout_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="⎋" FontSize="16" VerticalAlignment="Center"
                                       Foreground="#FC8181" Margin="0,0,12,0"/>
                            <TextBlock Text="Logout" FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="#FC8181"/>
                        </StackPanel>
                    </Button>

                    <!-- Nav Buttons -->
                    <StackPanel DockPanel.Dock="Top">
                        <Button x:Name="BtnDashboard"
                                Style="{StaticResource NavButtonActiveStyle}"
                                Click="NavButton_Click" Tag="Dashboard">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="⊞" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Dashboard"  FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnProfile"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Tag="Profile">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Profile"    FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnMeals"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Tag="Meals">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="🍽" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Meals"      FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnExercises"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Tag="Exercises">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="🏃" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Exercises"  FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnHealthMetrics"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Tag="HealthMetrics">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="❤" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Health Metrics" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnGoals"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Tag="Goals">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Goals"      FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnAdmin"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Tag="Admin">
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBlock Text="🛡" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Admin Panel" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════ -->
            <!--           MAIN CONTENT HOST (ContentControl)       -->
            <!-- ══════════════════════════════════════════════════ -->
            <ContentControl Grid.Column="1"
                            x:Name="MainContentArea"
                            Background="{StaticResource MainBg}"/>
        </Grid>
    </Grid>
</Window>
