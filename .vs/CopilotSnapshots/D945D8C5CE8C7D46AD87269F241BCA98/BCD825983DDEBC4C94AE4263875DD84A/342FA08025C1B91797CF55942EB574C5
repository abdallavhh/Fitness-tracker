<UserControl x:Class="FitnessTracker.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F4F8"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- ═══════════════════════════════════════════════════ -->
        <!--            LOGIN BUTTON STYLE                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#00B4D8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0,14"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0099B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007A99"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#B0D4E3"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--           TEXTBOX STYLE                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1A202C"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00B4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--           PASSWORDBOX STYLE                         -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1A202C"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00B4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--           DROP SHADOW EFFECT                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000" Opacity="0.12"
                          BlurRadius="28" ShadowDepth="8" Direction="270"/>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--                  MAIN LAYOUT                            -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Grid Background="#F0F4F8">
        <Grid.ColumnDefinitions>
            <!-- Left illustration section -->
            <ColumnDefinition Width="1*"/>
            <!-- Right login form section -->
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════ -->
        <!--           LEFT SECTION: BRANDING                  -->
        <!-- ══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#1A202C">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">
                <!-- Icon -->
                <Border Width="120" Height="120"
                        Background="#00B4D8"
                        CornerRadius="24"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32">
                    <TextBlock Text="🏋" FontSize="64"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <TextBlock Text="FITNESS TRACKER"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Subtitle -->
                <TextBlock Text="Track your fitness journey and achieve your health goals"
                           Foreground="#A0AEC0"
                           FontSize="16"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           LineHeight="24"/>

                <!-- Feature list -->
                <StackPanel Margin="0,48,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="#20C997" FontSize="16"
                                   Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Daily activity tracking" Foreground="#A0AEC0" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="#20C997" FontSize="16"
                                   Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Personal health metrics" Foreground="#A0AEC0" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" Foreground="#20C997" FontSize="16"
                                   Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Goal setting and progress" Foreground="#A0AEC0" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════ -->
        <!--           RIGHT SECTION: LOGIN FORM               -->
        <!-- ══════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Padding="60,40">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center" Spacing="0">
                    <!-- Header -->
                    <TextBlock Text="Welcome Back"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#1A202C"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Sign in to your account to continue"
                               FontSize="14"
                               Foreground="#718096"
                               Margin="0,0,0,32"/>

                    <!-- Error Message -->
                    <Border x:Name="ErrorBorder"
                            Background="#FEE2E2"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessage"
                                   Foreground="#DC2626"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Username/Email Field -->
                    <TextBlock Text="Username or Email"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1A202C"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="UsernameTextBox"
                             Style="{StaticResource LoginTextBoxStyle}"
                             Margin="0,0,0,20"
                             KeyDown="InputField_KeyDown"/>

                    <!-- Password Field -->
                    <TextBlock Text="Password"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1A202C"
                               Margin="0,0,0,8"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                 Margin="0,0,0,20"/>

                    <!-- Remember Me Checkbox -->
                    <Grid Margin="0,0,0,32">
                        <CheckBox x:Name="RememberMeCheckBox"
                                  Foreground="#718096"
                                  FontSize="13"
                                  VerticalAlignment="Center">
                            <TextBlock Text="Remember me" VerticalAlignment="Center"/>
                        </CheckBox>
                    </Grid>

                    <!-- Login Button -->
                    <Button x:Name="LoginButton"
                            Style="{StaticResource LoginButtonStyle}"
                            Content="Sign In"
                            Click="LoginButton_Click"
                            Margin="0,0,0,16"/>

                    <!-- Divider -->
                    <Grid Margin="0,16,0,16" Height="1" Background="#E2E8F0"/>

                    <!-- Demo Credentials Info -->
                    <Border Background="#F0FDF4"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,24">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Demo Credentials:"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#166534"/>
                            <TextBlock Text="Username: demo"
                                       FontSize="12"
                                       Foreground="#4B5563"
                                       FontFamily="Consolas"/>
                            <TextBlock Text="Password: password"
                                       FontSize="12"
                                       Foreground="#4B5563"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="Don't have an account? Contact your administrator"
                                   FontSize="12"
                                   Foreground="#718096"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
