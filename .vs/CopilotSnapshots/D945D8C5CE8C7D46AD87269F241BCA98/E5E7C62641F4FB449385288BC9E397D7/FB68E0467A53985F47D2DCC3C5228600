using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;

namespace FitnessTracker
{
    /// <summary>
    /// MainWindow: Shell window with sidebar navigation.
    /// Manages view switching between UserControls.
    /// </summary>
    public partial class MainWindow : Window
    {
        // ─── Cached view instances (lazy-load pattern) ────────────────────
        private DashboardView?    _dashboardView;
        private AdminDashboardView? _adminView;
        private LoginView?        _loginView;
        // Add more view instances here as you build them:
        // private ProfileView?     _profileView;
        // private MealsView?       _mealsView;

        // Currently active nav button (to manage active state styling)
        private Button? _activeNavButton;

        public MainWindow()
        {
            InitializeComponent();
            // Show login page on startup
            ShowLoginView();
        }

        // ──────────────────────────────────────────────────────────────────
        //  SHOW LOGIN VIEW
        //  Displays the login page and hides the sidebar/main content.
        // ──────────────────────────────────────────────────────────────────
        private void ShowLoginView()
        {
            // Hide sidebar and main content area
            Sidebar.Visibility = Visibility.Collapsed;
            MainContentArea.Visibility = Visibility.Collapsed;

            // Create and show login view
            _loginView = new LoginView();
            _loginView.LoginSuccessful += LoginView_LoginSuccessful;
            MainContentArea.Content = _loginView;
        }

        // ──────────────────────────────────────────────────────────────────
        //  LOGIN SUCCESSFUL HANDLER
        //  Called when user successfully authenticates.
        // ──────────────────────────────────────────────────────────────────
        private void LoginView_LoginSuccessful(object? sender, EventArgs e)
        {
            // Clear the login view from main content area
            MainContentArea.Content = null;

            // Show sidebar and main content area
            Sidebar.Visibility = Visibility.Visible;
            MainContentArea.Visibility = Visibility.Visible;

            // Navigate to dashboard
            NavigateTo("Dashboard");
            SetActiveButton(BtnDashboard);
        }

        // ──────────────────────────────────────────────────────────────────
        //  NAV BUTTON CLICK HANDLER
        //  All sidebar nav buttons route here via Tag property.
        // ──────────────────────────────────────────────────────────────────
        private void NavButton_Click(object sender, RoutedEventArgs e)
        {
            if (sender is Button btn)
            {
                var tag = btn.Tag?.ToString() ?? string.Empty;
                NavigateTo(tag);
                SetActiveButton(btn);
            }
        }

        // ──────────────────────────────────────────────────────────────────
        //  NAVIGATE TO VIEW
        //  Switches the ContentControl to the requested UserControl.
        // ──────────────────────────────────────────────────────────────────
        private void NavigateTo(string viewName)
        {
            MainContentArea.Content = viewName switch
            {
                "Dashboard"     => _dashboardView    ??= new DashboardView(),
                "Admin"         => _adminView         ??= new AdminDashboardView(),
                // Placeholder views — replace with real UserControls when built:
                "Profile"       => BuildPlaceholder("👤", "User Profile",        "#00B4D8"),
                "Meals"         => BuildPlaceholder("🍽", "Meals",               "#20C997"),
                "Exercises"     => BuildPlaceholder("🏃", "Exercise Log",        "#FF7043"),
                "HealthMetrics" => BuildPlaceholder("❤",  "Health Metrics",      "#FC8181"),
                "Goals"         => BuildPlaceholder("🎯", "Goals",               "#FFB300"),
                _               => _dashboardView    ??= new DashboardView()
            };
        }

        // ──────────────────────────────────────────────────────────────────
        //  ACTIVE BUTTON STYLING
        //  Resets previous active button and highlights the new one.
        // ──────────────────────────────────────────────────────────────────
        private void SetActiveButton(Button newActive)
        {
            // Reset old button to default nav style
            if (_activeNavButton is not null)
                _activeNavButton.Style = (Style)FindResource("NavButtonStyle");

            // Set new button to active style
            newActive.Style = (Style)FindResource("NavButtonActiveStyle");
            _activeNavButton = newActive;
        }

        // ──────────────────────────────────────────────────────────────────
        //  PLACEHOLDER VIEW BUILDER
        //  Creates a centered placeholder panel for views not yet built.
        // ──────────────────────────────────────────────────────────────────
        private static UIElement BuildPlaceholder(string icon, string title, string hexColor)
        {
            var color = (Color)ColorConverter.ConvertFromString(hexColor);

            return new Border
            {
                Background = new SolidColorBrush(Color.FromRgb(0xF0, 0xF4, 0xF8)),
                Child = new StackPanel
                {
                    HorizontalAlignment = HorizontalAlignment.Center,
                    VerticalAlignment   = VerticalAlignment.Center,
                    Children =
                    {
                        new TextBlock
                        {
                            Text                = icon,
                            FontSize            = 64,
                            HorizontalAlignment = HorizontalAlignment.Center,
                            Margin              = new Thickness(0, 0, 0, 16)
                        },
                        new TextBlock
                        {
                            Text                = title,
                            FontSize            = 28,
                            FontWeight          = FontWeights.Bold,
                            Foreground          = new SolidColorBrush(color),
                            HorizontalAlignment = HorizontalAlignment.Center,
                            FontFamily          = new FontFamily("Segoe UI")
                        },
                        new TextBlock
                        {
                            Text                = "This view is under construction.",
                            FontSize            = 14,
                            Foreground          = new SolidColorBrush(Color.FromRgb(0x71, 0x80, 0x96)),
                            HorizontalAlignment = HorizontalAlignment.Center,
                            Margin              = new Thickness(0, 8, 0, 0),
                            FontFamily          = new FontFamily("Segoe UI")
                        }
                    }
                }
            };
        }

        // ──────────────────────────────────────────────────────────────────
        //  LOGOUT HANDLER
        // ──────────────────────────────────────────────────────────────────
        private void BtnLogout_Click(object sender, RoutedEventArgs e)
        {
            var result = MessageBox.Show(
                "Are you sure you want to logout?",
                "Logout Confirmation",
                MessageBoxButton.YesNo,
                MessageBoxImage.Question);

            if (result == MessageBoxResult.Yes)
            {
                // Clear cached views on logout
                _dashboardView = null;
                _adminView = null;

                // Return to login view
                ShowLoginView();
            }
        }
    }
}
