<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:FitnessTracker.ViewModels"
                    xmlns:v="clr-namespace:FitnessTracker.Views">
    <DataTemplate DataType="{x:Type vm:LoginPageViewModel}">
        <v:LoginPage/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:DashboardHomeViewModel}">
        <v:DashboardHomeView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:UserProfileViewModel}">
        <v:UserProfileView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MealsViewModel}">
        <v:MealsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ExerciseLogViewModel}">
        <v:ExerciseLogView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:HealthMetricsViewModel}">
        <v:HealthMetricsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:GoalsViewModel}">
        <v:GoalsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AdminDashboardViewModel}">
        <v:AdminDashboardView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ManageUsersViewModel}">
        <v:ManageUsersView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AdminPlaceholderViewModel}">
        <v:AdminPlaceholderView/>
    </DataTemplate>
</ResourceDictionary>
